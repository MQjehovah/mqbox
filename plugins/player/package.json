{
  "name": "mqbox-plugin-player",
  "version": "1.0.0",
  "displayName": "媒体播放器",
  "description": "播放本地音频和视频文件",
  "main": "dist/index.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build"
  },
  "mqbox": {
    "id": "player",
    "displayName": "媒体播放器",
    "keywords": ["player", "play"],
    "permissions": ["storage", "files:read", "notification", "shell"]
  },
  "devDependencies": {
    "vite": "^5.0.0",
    "@vitejs/plugin-vue": "^5.0.0",
    "vue": "^3.4.0",
    "typescript": "~5.6.0"
  }
}