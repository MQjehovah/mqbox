{
  "name": "mqbox-builtin-everything",
  "version": "1.0.0",
  "displayName": "Everything 搜索",
  "description": "使用 Everything 进行快速文件搜索",
  "main": "dist/index.js",
  "scripts": {
    "build": "vite build"
  },
  "mqbox": {
    "id": "everything",
    "displayName": "Everything 搜索",
    "keywords": [],
    "permissions": [
      "files:read"
    ],
    "builtin": true,
    "defaultSearch": true,
    "hasPanel": false,
    "hasPage": false
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.6",
    "typescript": "^6.0.3",
    "vite": "^8.0.9"
  }
}
